{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "automerge": false,
  "minimumReleaseAge": "5 days",
  "labels": ["dependencies"],
  "commitMessagePrefix": "chore(deps):",

  "packageRules": [
    {
      "description": "Ignore all prerelease tags",
      "ignoreUnstable": true,
      "allowedVersions": "!/^.*(-alpha|-beta|-rc|-dev|-nightly|-preview)/",
      "matchPackageNames": [
        "*"
      ]
    },
    {
      "description": "linuxserver images use date-based build tags alongside semver — track semver only",
      "allowedVersions": "/^\\d+\\.\\d+\\.\\d+$/",
      "matchPackageNames": [
        "/^linuxserver//",
        "/^lscr.io/linuxserver//"
      ]
    },
    {
      "description": "qbittorrent: linuxserver switched to Ubuntu codename tags (e.g. 20.04.1 = Ubuntu Focal build 1) which are not version upgrades. Block anything with a two-digit major.",
      "allowedVersions": "/^[0-9]\\.\\d+\\.\\d+$/",
      "matchPackageNames": [
        "lscr.io/linuxserver/qbittorrent",
        "linuxserver/qbittorrent"
      ]
    },
    {
      "description": "Postgres major upgrades require pg_upgrade — ignore them",
      "matchPackageNames": ["postgres"],
      "matchUpdateTypes": ["major"]
    },
    {
      "description": "Scrutiny uses vX.Y.Z-omnibus compound tags — strip suffix for version comparison",
      "matchPackageNames": ["ghcr.io/analogj/scrutiny"],
      "versioning": "regex:^v(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)-omnibus$"
    },
    {
      "description": "prarr lidarr-plugins uses lidarr-plugins-X.Y.Z.N compound tags; map X.Y.N as semver (drop the Z segment, use N as patch)",
      "matchPackageNames": ["ghcr.io/linuxserver-labs/prarr"],
      "versioning": "regex:^lidarr-plugins-(?<major>\\d+)\\.(?<minor>\\d+)\\.\\d+\\.(?<patch>\\d+)$"
    },
    {
      "description": "subgen cpu variant uses YYYY.MM.D-cpu date-based tags",
      "matchPackageNames": ["mccloud/subgen"],
      "versioning": "regex:^(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)-cpu$"
    },
    {
      "description": "tdarr uses non-standard zero-padded patch versions like 2.50.01",
      "matchPackageNames": ["ghcr.io/haveagitgat/tdarr", "ghcr.io/haveagitgat/tdarr_node"],
      "versioning": "loose"
    },
    {
      "description": "watchback uses SHA-based tags from the user's own CI — skip Renovate",
      "matchPackageNames": ["ghcr.io/arishaig/watchback"],
      "enabled": false
    },
    {
      "description": "storyteller is on a private GitLab registry Renovate cannot query — skip",
      "matchPackageNames": ["registry.gitlab.com/storyteller-platform/storyteller"],
      "enabled": false
    },
    {
      "description": "cadvisor GitHub releases are ahead of GCR — v0.56+ not published to gcr.io; disable until GCR catches up",
      "matchPackageNames": ["google/cadvisor"],
      "enabled": false
    }
  ],

  "docker-compose": {
    "managerFilePatterns": [
      "/playbooks/provision/files/docker/docker-compose\\.yml/",
      "/playbooks/provision/files/seedbox/docker-compose\\.yml/",
      "/playbooks/provision/files/scrutiny/docker-compose\\.yml/",
      "/playbooks/provision/files/monitoring/docker-compose\\.yml/"
    ]
  },

  "customManagers": [
    {
      "customType": "regex",
      "description": "traefik binary version pin in vps.yml",
      "managerFilePatterns": ["/playbooks/provision/vps\\.yml/"],
      "matchStrings": ["traefik_version:\\s*\"(?<currentValue>[^\"]+)\""],
      "depNameTemplate": "traefik/traefik",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.+)$"
    },
    {
      "customType": "regex",
      "description": "alloy binary version pin in vps.yml",
      "managerFilePatterns": ["/playbooks/provision/vps\\.yml/"],
      "matchStrings": ["alloy_version:\\s*\"(?<currentValue>[^\"]+)\""],
      "depNameTemplate": "grafana/alloy",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.+)$"
    },
    {
      "customType": "regex",
      "description": "node_exporter version pin in vps.yml and common.yml",
      "managerFilePatterns": ["/playbooks/provision/vps\\.yml/", "/playbooks/provision/common\\.yml/"],
      "matchStrings": ["node_exporter_version:\\s*\"(?<currentValue>[^\"]+)\""],
      "depNameTemplate": "prometheus/node_exporter",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.+)$"
    },
    {
      "customType": "regex",
      "description": "promtool version pin (CI) in runner.yml",
      "managerFilePatterns": ["/playbooks/provision/runner\\.yml/"],
      "matchStrings": ["prometheus_version:\\s*\"(?<currentValue>[^\"]+)\""],
      "depNameTemplate": "prometheus/prometheus",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.+)$"
    },
    {
      "customType": "regex",
      "description": "amtool version pin (CI) in runner.yml",
      "managerFilePatterns": ["/playbooks/provision/runner\\.yml/"],
      "matchStrings": ["alertmanager_version:\\s*\"(?<currentValue>[^\"]+)\""],
      "depNameTemplate": "prometheus/alertmanager",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.+)$"
    },
    {
      "customType": "regex",
      "description": "kustomize version pin (CI) in runner.yml",
      "managerFilePatterns": ["/playbooks/provision/runner\\.yml/"],
      "matchStrings": ["kustomize_version:\\s*\"(?<currentValue>[^\"]+)\""],
      "depNameTemplate": "kubernetes-sigs/kustomize",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^kustomize/v(?<version>.+)$"
    },
    {
      "customType": "regex",
      "description": "kubeconform version pin (CI) in runner.yml",
      "managerFilePatterns": ["/playbooks/provision/runner\\.yml/"],
      "matchStrings": ["kubeconform_version:\\s*\"(?<currentValue>[^\"]+)\""],
      "depNameTemplate": "yannh/kubeconform",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.+)$"
    },
    {
      "customType": "regex",
      "description": "cadvisor lives on gcr.io (unsupported registry) — track via GitHub releases",
      "managerFilePatterns": [
        "/playbooks/provision/files/docker/docker-compose\\.yml/",
        "/playbooks/provision/files/monitoring/docker-compose\\.yml/",
        "/playbooks/provision/files/scrutiny/docker-compose\\.yml/",
        "/playbooks/provision/files/seedbox/docker-compose\\.yml/"
      ],
      "matchStrings": ["gcr\\.io/cadvisor/cadvisor:(?<currentValue>[^\\s'\"\\n]+)"],
      "depNameTemplate": "google/cadvisor",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "description": "adguard Jinja2 template — regex extract image versions (docker-compose manager cannot parse j2 files with Jinja2 blocks)",
      "managerFilePatterns": ["/playbooks/provision/templates/adguard/docker-compose\\.yml\\.j2/"],
      "matchStrings": ["image:\\s+(?<depName>[^:\\s]+):(?<currentValue>[^\\s'\"\\n]+)"],
      "datasourceTemplate": "docker"
    }
  ]
}
