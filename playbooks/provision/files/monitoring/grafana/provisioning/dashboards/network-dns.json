    {
      "id": 16,
      "type": "timeseries",
      "title": "Network Bandwidth (Top Clients)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 19
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "topk(10, rate(unpoller_client_receive_bytes_total[5m]))",
          "legendFormat": "{{ name }} rx",
          "refId": "A"
        },
        {
          "expr": "topk(10, -rate(unpoller_client_transmit_bytes_total[5m]))",
          "legendFormat": "{{ name }} tx",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "fillOpacity": 10,
            "gradientMode": "opacity",
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max"
          ]
        }
      }
    },
    {
      "id": 17,
      "type": "table",
      "title": "Connected Clients",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 27
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "unpoller_client_uptime_seconds > 0",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "job": true,
              "instance": true,
              "source": true,
              "oui": true,
              "radio_name": true,
              "radio_proto": true,
              "radio": true,
              "vlan": true,
              "network": true
            },
            "indexByName": {
              "name": 0,
              "mac": 1,
              "ip": 2,
              "wired": 3,
              "ap_name": 4,
              "sw_name": 5,
              "site_name": 6,
              "Value": 7
            },
            "renameByName": {
              "name": "Client",
              "mac": "MAC",
              "ip": "IP",
              "wired": "Wired",
              "ap_name": "AP",
              "sw_name": "Switch",
              "site_name": "Site",
              "Value": "Uptime"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            }
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Uptime"
            },
            "properties": [
              {
                "id": "unit",
                "value": "s"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Wired"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "true": {
                        "text": "Wired"
                      },
                      "false": {
                        "text": "WiFi"
                      }
                    }
                  }
                ]
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "Uptime",
            "desc": true
          }
        ]
      }
    },
    {
      "type": "row",
