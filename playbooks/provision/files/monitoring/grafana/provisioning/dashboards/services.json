{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "type": "row",
      "title": "Media Stack",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "panels": []
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Sonarr Series",
      "gridPos": { "h": 3, "w": 4, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sonarr_series_total", "refId": "A" }],
      "fieldConfig": {
        "defaults": { "color": { "mode": "fixed", "fixedColor": "text" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "text", "value": null }] } },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "none", "colorMode": "none" }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Sonarr Missing",
      "gridPos": { "h": 3, "w": 4, "x": 4, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sonarr_episode_missing_total", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 50 }, { "color": "red", "value": 200 }] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "none", "colorMode": "background" }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Radarr Movies",
      "gridPos": { "h": 3, "w": 4, "x": 8, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "radarr_movie_total", "refId": "A" }],
      "fieldConfig": {
        "defaults": { "color": { "mode": "fixed", "fixedColor": "text" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "text", "value": null }] } },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "none", "colorMode": "none" }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Radarr Missing",
      "gridPos": { "h": 3, "w": 4, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "radarr_movie_missing_total", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 20 }, { "color": "red", "value": 100 }] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "none", "colorMode": "background" }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Lidarr Artists",
      "gridPos": { "h": 3, "w": 4, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "lidarr_artists_total", "refId": "A" }],
      "fieldConfig": {
        "defaults": { "color": { "mode": "fixed", "fixedColor": "text" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "text", "value": null }] } },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "none", "colorMode": "none" }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Prowlarr Failures",
      "description": "Indexers with query failures in Prowlarr stats window",
      "gridPos": { "h": 3, "w": 4, "x": 20, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "count(prowlarr_indexer_query_failures_total > 0) OR vector(0)", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "text", "value": null }, { "color": "red", "value": 1 }] },
          "noValue": "0"
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "none", "colorMode": "value" }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Sonarr Queue",
      "gridPos": { "h": 3, "w": 6, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sonarr_queue_total", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "orange", "value": 20 }] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "area", "colorMode": "background" }
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Radarr Queue",
      "gridPos": { "h": 3, "w": 6, "x": 6, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "radarr_queue_total", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "orange", "value": 20 }] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "area", "colorMode": "background" }
    },
    {
      "id": 9,
      "type": "stat",
      "title": "Lidarr Queue",
      "gridPos": { "h": 3, "w": 6, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "lidarr_queue_total", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "orange", "value": 20 }] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "area", "colorMode": "background" }
    },
    {
      "id": 10,
      "type": "stat",
      "title": "Media Free Space",
      "gridPos": { "h": 3, "w": 6, "x": 18, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sonarr_rootfolder_freespace_bytes", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "orange", "value": 107374182400 }, { "color": "green", "value": 536870912000 }] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "area", "colorMode": "background" }
    },
    {
      "type": "row",
      "title": "Download Activity",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "panels": []
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Queue Sizes",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sonarr_queue_total", "legendFormat": "Sonarr", "refId": "A" },
        { "expr": "radarr_queue_total", "legendFormat": "Radarr", "refId": "B" },
        { "expr": "lidarr_queue_total", "legendFormat": "Lidarr", "refId": "C" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "fillOpacity": 10,
            "gradientMode": "opacity",
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "qBittorrent Speeds",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "qbittorrent_global_download_speed_bytes", "legendFormat": "Download", "refId": "A" },
        { "expr": "-qbittorrent_global_upload_speed_bytes", "legendFormat": "Upload", "refId": "B" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "fillOpacity": 10,
            "gradientMode": "opacity",
            "showPoints": "never"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Download" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#73BF69" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Upload" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#5794F2" } }]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "type": "row",
      "title": "Quality Breakdown",
      "collapsed": true,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 },
      "panels": [
        {
          "id": 13,
          "type": "piechart",
          "title": "Sonarr Quality Profile",
          "gridPos": { "h": 8, "w": 8, "x": 0, "y": 17 },
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "targets": [{ "expr": "sonarr_series_quality_total", "legendFormat": "{{ quality }}", "refId": "A" }],
          "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } }, "overrides": [] },
          "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "legend": { "displayMode": "table", "placement": "right" } }
        },
        {
          "id": 14,
          "type": "piechart",
          "title": "Radarr Quality Profile",
          "gridPos": { "h": 8, "w": 8, "x": 8, "y": 17 },
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "targets": [{ "expr": "radarr_movie_quality_total", "legendFormat": "{{ quality }}", "refId": "A" }],
          "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } }, "overrides": [] },
          "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "legend": { "displayMode": "table", "placement": "right" } }
        },
        {
          "id": 15,
          "type": "timeseries",
          "title": "Prowlarr Indexer Response Times",
          "gridPos": { "h": 8, "w": 8, "x": 16, "y": 17 },
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "targets": [{ "expr": "prowlarr_indexer_average_response_time_ms", "legendFormat": "{{ indexer }}", "refId": "A" }],
          "fieldConfig": {
            "defaults": {
              "unit": "ms",
              "color": { "mode": "palette-classic" },
              "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 1, "fillOpacity": 10, "gradientMode": "opacity", "showPoints": "never" }
            },
            "overrides": []
          },
          "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "list", "placement": "bottom" } }
        }
      ]
    },
    {
      "type": "row",
      "title": "Disk Health",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "panels": []
    },
    {
      "id": 16,
      "type": "table",
      "title": "Scrutiny Drive Status",
      "description": "S.M.A.R.T. drive health from Scrutiny",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "scrutiny_device_status",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true, "job": true, "instance": true },
            "renameByName": { "device": "Device", "model": "Model", "serial": "Serial", "Value": "Status" }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "cellOptions": { "type": "auto" } }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Status" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "0": { "text": "Healthy", "color": "green" }, "1": { "text": "Warning", "color": "orange" }, "2": { "text": "Failed", "color": "red" } } }
                ]
              },
              { "id": "custom.cellOptions", "value": { "type": "color-text" } }
            ]
          }
        ]
      },
      "options": { "showHeader": true }
    }
  ],
  "schemaVersion": 39,
  "tags": ["services"],
  "templating": { "list": [] },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Services",
  "uid": "services",
  "version": 1
}
