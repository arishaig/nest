{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "type": "row",
      "title": "Overview",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "panels": []
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Hosts Up",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "count(up{job=\"node\"} == 1)",
          "legendFormat": "Up",
          "refId": "A"
        },
        {
          "expr": "count(up{job=\"node\"})",
          "legendFormat": "Total",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 8 },
              { "color": "green", "value": 10 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      }
    },
    {
      "id": 2,
      "type": "gauge",
      "title": "PVE CPU",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "pve_cpu_usage_ratio{id=~\"node/.*\"} * 100",
          "legendFormat": "{{ id }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 3,
      "type": "gauge",
      "title": "PVE Memory",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(pve_memory_usage_bytes{id=~\"node/.*\"}) / sum(pve_memory_size_bytes{id=~\"node/.*\"}) * 100",
          "legendFormat": "Used",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Docker Containers",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "count(container_memory_usage_bytes{name!=\"\"} > 0)",
          "legendFormat": "Running",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "text" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "text", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "none",
        "graphMode": "none"
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Avg CPU",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "avg(100 - (avg by(instance) (rate(node_cpu_seconds_total{mode=\"idle\",job=\"node\"}[5m])) * 100))",
          "legendFormat": "Avg CPU",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 60 },
              { "color": "red", "value": 85 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Avg Memory",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "avg((1 - node_memory_MemAvailable_bytes{job=\"node\"} / node_memory_MemTotal_bytes{job=\"node\"}) * 100)",
          "legendFormat": "Avg Memory",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      }
    },
    {
      "type": "row",
      "title": "Host Resources",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "panels": []
    },
    {
      "id": 7,
      "type": "table",
      "title": "All Hosts",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "up{job=\"node\"}",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "A"
        },
        {
          "expr": "100 - (avg by(instance) (rate(node_cpu_seconds_total{mode=\"idle\",job=\"node\"}[5m])) * 100)",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "B"
        },
        {
          "expr": "(1 - node_memory_MemAvailable_bytes{job=\"node\"} / node_memory_MemTotal_bytes{job=\"node\"}) * 100",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "C"
        },
        {
          "expr": "node_memory_MemTotal_bytes{job=\"node\"}",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "D"
        },
        {
          "expr": "(1 - node_filesystem_avail_bytes{job=\"node\",mountpoint=\"/\",fstype!~\"tmpfs|overlay\"} / node_filesystem_size_bytes{job=\"node\",mountpoint=\"/\",fstype!~\"tmpfs|overlay\"}) * 100",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "E"
        },
        {
          "expr": "node_filesystem_size_bytes{job=\"node\",mountpoint=\"/\",fstype!~\"tmpfs|overlay\"}",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "F"
        },
        {
          "expr": "time() - node_boot_time_seconds{job=\"node\"}",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "G"
        }
      ],
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "job": true,
              "cpu": true,
              "mode": true,
              "mountpoint": true,
              "fstype": true,
              "device": true
            },
            "indexByName": {
              "instance": 0,
              "Value #A": 1,
              "Value #B": 2,
              "Value #C": 3,
              "Value #D": 4,
              "Value #E": 5,
              "Value #F": 6,
              "Value #G": 7
            },
            "renameByName": {
              "instance": "Host",
              "Value #A": "Status",
              "Value #B": "CPU %",
              "Value #C": "Memory %",
              "Value #D": "Total RAM",
              "Value #E": "Disk %",
              "Value #F": "Disk Size",
              "Value #G": "Uptime"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" }
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Status" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-text" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "CPU %" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "decimals", "value": 1 },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "orange", "value": 70 },
                    { "color": "red", "value": 90 }
                  ]
                }
              },
              {
                "id": "custom.cellOptions",
                "value": { "type": "gauge", "mode": "basic" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Memory %" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "decimals", "value": 1 },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "orange", "value": 70 },
                    { "color": "red", "value": 90 }
                  ]
                }
              },
              {
                "id": "custom.cellOptions",
                "value": { "type": "gauge", "mode": "basic" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Total RAM" },
            "properties": [
              { "id": "unit", "value": "bytes" },
              { "id": "decimals", "value": 1 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Disk %" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "decimals", "value": 1 },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "orange", "value": 75 },
                    { "color": "red", "value": 90 }
                  ]
                }
              },
              {
                "id": "custom.cellOptions",
                "value": { "type": "gauge", "mode": "basic" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Disk Size" },
            "properties": [
              { "id": "unit", "value": "bytes" },
              { "id": "decimals", "value": 1 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Uptime" },
            "properties": [
              { "id": "unit", "value": "s" },
              { "id": "decimals", "value": 0 }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Host", "desc": false }]
      }
    },
    {
      "type": "row",
      "title": "Resource Trends",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "panels": []
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "CPU Usage by Host",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "100 - (avg by(instance) (rate(node_cpu_seconds_total{mode=\"idle\",job=\"node\"}[5m])) * 100)",
          "legendFormat": "{{ instance }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "fillOpacity": 10,
            "gradientMode": "opacity",
            "pointSize": 5,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Memory Usage by Host",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "(1 - node_memory_MemAvailable_bytes{job=\"node\"} / node_memory_MemTotal_bytes{job=\"node\"}) * 100",
          "legendFormat": "{{ instance }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "fillOpacity": 10,
            "gradientMode": "opacity",
            "pointSize": 5,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Network Traffic by Host",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 27 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by(instance) (rate(node_network_receive_bytes_total{job=\"node\",device!~\"lo|veth.*|br.*|docker.*|cali.*|flannel.*\"}[5m]))",
          "legendFormat": "{{ instance }} rx",
          "refId": "A"
        },
        {
          "expr": "-sum by(instance) (rate(node_network_transmit_bytes_total{job=\"node\",device!~\"lo|veth.*|br.*|docker.*|cali.*|flannel.*\"}[5m]))",
          "legendFormat": "{{ instance }} tx",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "fillOpacity": 10,
            "gradientMode": "opacity",
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      }
    },
    {
      "type": "row",
      "title": "Proxmox Guests",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 35 },
      "panels": []
    },
    {
      "id": 11,
      "type": "table",
      "title": "PVE Guests",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 36 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "pve_up{id=~\"(lxc|qemu)/.*\"} * on(id) group_left(name, type) pve_guest_info",
          "format": "table",
          "instant": true,
          "refId": "A"
        },
        {
          "expr": "pve_cpu_usage_ratio{id=~\"(lxc|qemu)/.*\"} * 100 * on(id) group_left(name, type) pve_guest_info",
          "format": "table",
          "instant": true,
          "refId": "B"
        },
        {
          "expr": "pve_memory_usage_bytes{id=~\"(lxc|qemu)/.*\"} * on(id) group_left(name, type) pve_guest_info",
          "format": "table",
          "instant": true,
          "refId": "C"
        },
        {
          "expr": "pve_memory_size_bytes{id=~\"(lxc|qemu)/.*\"} * on(id) group_left(name, type) pve_guest_info",
          "format": "table",
          "instant": true,
          "refId": "D"
        },
        {
          "expr": "pve_disk_usage_bytes{id=~\"(lxc|qemu)/.*\"} * on(id) group_left(name, type) pve_guest_info",
          "format": "table",
          "instant": true,
          "refId": "E"
        },
        {
          "expr": "pve_disk_size_bytes{id=~\"(lxc|qemu)/.*\"} * on(id) group_left(name, type) pve_guest_info",
          "format": "table",
          "instant": true,
          "refId": "F"
        }
      ],
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "job": true,
              "instance": true
            },
            "indexByName": {
              "name": 0,
              "id": 1,
              "type": 2,
              "node": 3,
              "Value #A": 4,
              "Value #B": 5,
              "Value #C": 6,
              "Value #D": 7,
              "Value #E": 8,
              "Value #F": 9
            },
            "renameByName": {
              "name": "Name",
              "id": "ID",
              "type": "Type",
              "node": "Node",
              "Value #A": "Status",
              "Value #B": "CPU %",
              "Value #C": "Memory Used",
              "Value #D": "Memory Total",
              "Value #E": "Disk Used",
              "Value #F": "Disk Total"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" }
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Status" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "0": { "text": "Stopped", "color": "red" }, "1": { "text": "Running", "color": "green" } } }
                ]
              },
              { "id": "custom.cellOptions", "value": { "type": "color-text" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "CPU %" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "decimals", "value": 1 }
            ]
          },
          {
            "matcher": { "id": "byRegexp", "options": "Memory.*" },
            "properties": [
              { "id": "unit", "value": "bytes" },
              { "id": "decimals", "value": 1 }
            ]
          },
          {
            "matcher": { "id": "byRegexp", "options": "Disk.*" },
            "properties": [
              { "id": "unit", "value": "bytes" },
              { "id": "decimals", "value": 1 }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Name", "desc": false }]
      }
    },
    {
      "type": "row",
      "title": "Docker Containers",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 46 },
      "panels": []
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Top Containers by CPU",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 47 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "topk(10, sum by(name) (rate(container_cpu_usage_seconds_total{name!=\"\"}[5m])) * 100)",
          "legendFormat": "{{ name }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "fillOpacity": 10,
            "gradientMode": "opacity",
            "showPoints": "never",
            "stacking": { "mode": "none" }
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      }
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Top Containers by Memory",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 47 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "topk(10, container_memory_usage_bytes{name!=\"\"})",
          "legendFormat": "{{ name }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "fillOpacity": 10,
            "gradientMode": "opacity",
            "showPoints": "never",
            "stacking": { "mode": "none" }
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["infrastructure"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Infrastructure Health",
  "uid": "infrastructure-health",
  "version": 1
}
