[Unit]
Description=FoundryVTT Game Server
After=network.target

[Service]
Type=simple
User={{ foundry_user }}
WorkingDirectory={{ foundry_install_dir }}
ExecStart=/usr/bin/node {{ foundry_install_dir }}/main.js --dataPath={{ foundry_data_dir }} --port={{ foundry_port }}
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
