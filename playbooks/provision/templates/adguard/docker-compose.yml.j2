services:
  adguard-exporter:
    image: ghcr.io/henrywhitaker3/adguard-exporter:latest
    container_name: adguard-exporter
    restart: unless-stopped
    environment:
      - ADGUARD_SERVERS={{ adguard_self_url }}
      - ADGUARD_USERNAMES={{ adguard_exporter_username }}
      - ADGUARD_PASSWORDS=${ADGUARD_PASSWORD}
      - INTERVAL=30s
    ports:
      - "9618:9618"

{% if adguard_primary | default(false) %}
  # Dynamic DNS — primary only
  cloudflare-ddns:
    image: favonia/cloudflare-ddns:latest
    container_name: cloudflare-ddns
    restart: always
    read_only: true
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    environment:
      - CF_API_TOKEN=${CLOUDFLARE_DNS_EDIT_API_KEY}
      - DOMAINS=vpn.arishaig.site,dns.arishaig.site
      - PROXIED=false
      - TTL=300
{% endif %}
