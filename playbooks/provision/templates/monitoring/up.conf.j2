[poller]
  debug = false
  quiet = false

[prometheus]
  disable = false
  http_listen = "0.0.0.0:9130"
  report_errors = false

[unifi]
  dynamic = false

[[unifi.controller]]
  url = "https://192.168.1.1"
  user = "{{ unpoller_unifi_user }}"
  pass = "{{ unpoller_unifi_pass }}"
  verify_ssl = false
  save_sites = true
  save_ids = false
  save_events = false
  save_alarms = false
  save_dpi = false
  sites = ["default"]
