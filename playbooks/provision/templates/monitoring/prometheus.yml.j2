global:
  scrape_interval: 30s
  evaluation_interval: 30s
  scrape_timeout: 10s

alerting:
  alertmanagers:
    - static_configs:
        - targets: ['alertmanager:9093']

rule_files:
  - /etc/prometheus/rules/*.yml

scrape_configs:

  - job_name: 'prometheus'
    static_configs:
      - targets: ['localhost:9090']

  - job_name: 'node'
    static_configs:
      - targets:
          - 'proxmox.local.arishaig.site:9100'
          - 'monitoring.local.arishaig.site:9100'
          - 'docker.arishaig.site:9100'
          - 'torrent.local.arishaig.site:9100'
          - 'files.arishaig.site:9100'
          - 'scrutiny.local.arishaig.site:9100'
          - 'musicbrainz.arishaig.site:9100'
          - 'backup.local.arishaig.site:9100'
          - 'dns.arishaig.site:9100'
    relabel_configs:
      - source_labels: [__address__]
        regex: '([^:]+):\d+'
        target_label: instance

  - job_name: 'vps'
    static_configs:
      - targets: ['10.10.0.1:9100']
        labels:
          instance: 'vps-proxy'

  - job_name: 'traefik-vps'
    static_configs:
      - targets: ['10.10.0.1:8080']
        labels:
          instance: 'vps-proxy'

  - job_name: 'cadvisor'
    static_configs:
      - targets:
          - 'monitoring.local.arishaig.site:8080'
          - 'docker.arishaig.site:8081'
          - 'torrent.local.arishaig.site:8081'
          - 'scrutiny.local.arishaig.site:8081'

  - job_name: 'proxmox'
    static_configs:
      - targets:
          - 'proxmox.local.arishaig.site'
    metrics_path: /pve
    params:
      module: [default]
      cluster: ['1']
      node: ['1']
    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__param_target]
        target_label: instance
      - target_label: __address__
        replacement: 'monitoring.local.arishaig.site:9221'

  - job_name: 'adguard'
    static_configs:
      - targets: ['dns.arishaig.site:9618']
        labels:
          dns_role: primary
      - targets: ['192.168.7.8:9618']
        labels:
          dns_role: secondary
      - targets: ['10.10.0.1:9618']
        labels:
          dns_role: tertiary

  - job_name: 'unbound'
    static_configs:
      - targets: ['dns.arishaig.site:9167']
        labels:
          dns_role: primary
      - targets: ['192.168.7.8:9167']
        labels:
          dns_role: secondary
      - targets: ['10.10.0.1:9167']
        labels:
          dns_role: tertiary

  - job_name: 'unpoller'
    static_configs:
      - targets: ['unpoller:9130']

  - job_name: 'sonarr'
    static_configs:
      - targets: ['docker.arishaig.site:9707']
    metrics_path: /metrics

  - job_name: 'radarr'
    static_configs:
      - targets: ['docker.arishaig.site:9708']
    metrics_path: /metrics

  - job_name: 'lidarr'
    static_configs:
      - targets: ['docker.arishaig.site:9709']
    metrics_path: /metrics

  - job_name: 'prowlarr'
    static_configs:
      - targets: ['docker.arishaig.site:9710']
    metrics_path: /metrics

  - job_name: 'bazarr'
    static_configs:
      - targets: ['docker.arishaig.site:9711']
    metrics_path: /metrics

  - job_name: 'qbittorrent'
    static_configs:
      - targets: ['torrent.local.arishaig.site:9022']

  - job_name: 'postgres'
    static_configs:
      - targets: ['docker.arishaig.site:9187']

  - job_name: 'scrutiny'
    static_configs:
      - targets: ['scrutiny.local.arishaig.site:8080']
    metrics_path: /api/metrics

  - job_name: 'homeassistant'
    static_configs:
      - targets: ['casa.local.arishaig.site:8123']
    metrics_path: /api/prometheus
    bearer_token: {{ homeassistant_bearer_token }}

  - job_name: 'wled'
    static_configs:
      - targets: ['backlight.arishaig.site:80']
    metrics_path: /json

  - job_name: 'speedtest'
    scrape_interval: 1h
    scrape_timeout: 90s
    static_configs:
      - targets: ['speedtest-exporter:9798']
