global:
  scrape_interval: 30s
  evaluation_interval: 30s
  scrape_timeout: 10s

alerting:
  alertmanagers:
    - static_configs:
        - targets: ['alertmanager:9093']

rule_files:
  - /etc/prometheus/rules/*.yml

scrape_configs:

  - job_name: 'prometheus'
    static_configs:
      - targets: ['localhost:9090']

  - job_name: 'node'
    static_configs:
      - targets:
          - 'proxmox.local.arishaig.site:9100'
          - 'monitoring.local.arishaig.site:9100'
          - 'files.arishaig.site:9100'
          - 'musicbrainz.arishaig.site:9100'
          - 'backup.local.arishaig.site:9100'
          - 'dns.arishaig.site:9100'
          - '192.168.1.46:9100'
          - '192.168.1.182:9100'
    relabel_configs:
      - source_labels: [__address__]
        regex: '([^:]+):\d+'
        target_label: instance
      - source_labels: [instance]
        regex: '192\.168\.1\.46'
        target_label: instance
        replacement: 'scrutiny.local.arishaig.site'
      - source_labels: [instance]
        regex: '192\.168\.1\.182'
        target_label: instance
        replacement: 'torrent.local.arishaig.site'

  - job_name: 'vps'
    static_configs:
      - targets: ['10.10.0.1:9100']
        labels:
          instance: 'vps-proxy'

  - job_name: 'traefik-vps'
    static_configs:
      - targets: ['10.10.0.1:8080']
        labels:
          instance: 'vps-proxy'

  - job_name: 'cadvisor'
    static_configs:
      - targets:
          - 'monitoring.local.arishaig.site:8080'
      - targets: ['192.168.1.46:8081']
        labels:
          instance: 'scrutiny.local.arishaig.site'
      - targets: ['192.168.1.182:8081']
        labels:
          instance: 'torrent.local.arishaig.site'

  - job_name: 'proxmox'
    static_configs:
      - targets:
          - 'proxmox.local.arishaig.site'
    metrics_path: /pve
    params:
      module: [default]
      cluster: ['1']
      node: ['1']
    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__param_target]
        target_label: instance
      - target_label: __address__
        replacement: 'monitoring.local.arishaig.site:9221'

  - job_name: 'adguard'
    static_configs:
      - targets: ['dns.arishaig.site:9618']
        labels:
          dns_role: primary
      - targets: ['192.168.7.8:9618']
        labels:
          dns_role: secondary
      - targets: ['10.10.0.1:9618']
        labels:
          dns_role: tertiary

  - job_name: 'unbound'
    static_configs:
      - targets: ['dns.arishaig.site:9167']
        labels:
          dns_role: primary
      - targets: ['192.168.7.8:9167']
        labels:
          dns_role: secondary
      - targets: ['10.10.0.1:9167']
        labels:
          dns_role: tertiary

  - job_name: 'unpoller'
    static_configs:
      - targets: ['unpoller:9130']

  - job_name: 'loki'
    static_configs:
      - targets: ['loki:3100']

  # k8s cluster IPs: .110/.111/.112 are node IPs, .115 is the Talos API VIP
  # (never scrape it: kube-proxy nftables mode only serves NodePorts on
  # primary node IPs), .116 is the shared MetalLB metrics LB, .117 is the
  # ingress LB.
  - job_name: 'sonarr'
    static_configs:
      - targets: ['192.168.1.116:9707']
    metrics_path: /metrics

  - job_name: 'radarr'
    static_configs:
      - targets: ['192.168.1.116:9708']
    metrics_path: /metrics

  - job_name: 'lidarr'
    static_configs:
      - targets: ['192.168.1.116:9709']
    metrics_path: /metrics

  - job_name: 'prowlarr'
    static_configs:
      - targets: ['192.168.1.116:9710']
    metrics_path: /metrics

  - job_name: 'bazarr'
    static_configs:
      - targets: ['192.168.1.116:9711']
    metrics_path: /metrics

  - job_name: 'qbittorrent'
    static_configs:
      - targets: ['192.168.1.182:9022']
        labels:
          instance: 'torrent.local.arishaig.site'

  - job_name: 'traefik-k8s'
    static_configs:
      - targets: ['192.168.1.117:8080']
        labels:
          instance: 'talos'

  - job_name: 'authelia'
    static_configs:
      - targets: ['192.168.1.116:9959']
        labels:
          instance: 'talos'

  - job_name: 'redis'
    static_configs:
      - targets: ['192.168.1.116:9121']
        labels:
          instance: 'talos'

  - job_name: 'postgres'
    static_configs:
      - targets: ['192.168.1.116:9187']
        labels:
          instance: 'talos'

  - job_name: 'wled'
    static_configs:
      - targets: ['backlight.arishaig.site:80']
    metrics_path: /json

  - job_name: 'speedtest'
    scrape_interval: 1h
    scrape_timeout: 90s
    static_configs:
      - targets: ['speedtest-exporter:9798']

  - job_name: 'blackbox'
    scrape_interval: 60s
    metrics_path: /probe
    params:
      module: [http_endpoint]
    static_configs:
      - targets:
          - https://auth.arishaig.site
          - https://bazarr.arishaig.site
          - https://backup.arishaig.site
          - https://copyparty.arishaig.site
          - https://dash.arishaig.site
          - https://jellyfin.arishaig.site
          - https://lidarr.arishaig.site
          - https://mcp.arishaig.site
          - https://mealie.arishaig.site
          - https://medialyze.arishaig.site
          - https://monitoring.arishaig.site
          - https://nzbd.arishaig.site
          - https://prowlarr.arishaig.site
          - https://proxmox.arishaig.site
          - https://radarr.arishaig.site
          - https://recommendarr.arishaig.site
          - https://requests.arishaig.site
          - https://scrutiny.arishaig.site
          - https://sonarr.arishaig.site
          - https://storyteller.arishaig.site
          - https://torrent.arishaig.site
          - https://tunarr.arishaig.site
          - https://watcharr.arishaig.site
          - https://watchback.arishaig.site
    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__param_target]
        target_label: instance
      - target_label: __address__
        replacement: blackbox-exporter:9115
