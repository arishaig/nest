// Push to Loki on monitoring LXC
loki.write "loki" {
  endpoint {
    url = "http://192.168.1.44:3100/loki/api/v1/push"
  }
}

// Docker container log discovery
discovery.docker "containers" {
  host = "unix:///var/run/docker.sock"
}

discovery.relabel "docker" {
  targets = discovery.docker.containers.targets

  rule {
    source_labels = ["__meta_docker_container_name"]
    regex         = "/(.*)"
    target_label  = "container"
  }

  rule {
    source_labels = ["__meta_docker_container_label_com_docker_compose_service"]
    target_label  = "service"
  }
}

loki.source.docker "containers" {
  host       = "unix:///var/run/docker.sock"
  targets    = discovery.relabel.docker.output
  forward_to = [loki.write.loki.receiver]
  labels = {
    job  = "docker",
    host = "{{ inventory_hostname }}",
  }
}

// journald logs
loki.relabel "journal" {
  forward_to = [loki.write.loki.receiver]

  rule {
    source_labels = ["__journal__systemd_unit"]
    target_label  = "unit"
  }
}

loki.source.journal "journal" {
  max_age    = "12h"
  forward_to = [loki.relabel.journal.receiver]
  labels = {
    job  = "journal",
    host = "{{ inventory_hostname }}",
  }
}

{% if inventory_hostname == 'docker' %}
// Internal Traefik access log — written to file, not stdout.
// Mirrors the VPS traefik-access pipeline so both can be queried with job="traefik-access".
local.file_match "traefik_access" {
  path_targets = [{
    __address__ = "localhost",
    __path__    = "/mnt/app_config/traefik/logs/access.log",
    job         = "traefik-access",
    host        = "docker",
  }]
}

loki.process "traefik_access_json" {
  forward_to = [loki.write.loki.receiver]

  stage.json {
    expressions = {
      router = "RouterName",
      status = "DownstreamStatus",
    }
  }

  stage.labels {
    values = {
      router = "router",
      status = "status",
    }
  }
}

loki.source.file "traefik_access" {
  targets    = local.file_match.traefik_access.targets
  forward_to = [loki.process.traefik_access_json.receiver]
}
{% endif %}
