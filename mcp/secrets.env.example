# nest-mcp credentials — all sourced from the ansible vault.
# Generated by: ./scripts/gen-mcp-secrets.sh
# Populated by: ./scripts/pull-secrets.sh (reads vault + live infra)
#
# Workflow:
#   1. Create a "nest-mcp" API key in Jellyfin dashboard (one-time)
#   2. Run terraform apply (one-time, creates the Proxmox token)
#   3. Run pull-secrets.sh  → captures everything into the vault
#   4. Run gen-mcp-secrets.sh  → writes this file from the vault
#   5. Re-run steps 3-4 whenever credentials rotate

NEST_PROXMOX_TOKEN=nest-mcp@pve!nest-mcp=REPLACE   # vault: nest_mcp_pve_token
NEST_UNIFI_USERNAME=REPLACE                          # vault: unpoller_unifi_user
NEST_UNIFI_PASSWORD=REPLACE                          # vault: unpoller_unifi_pass
NEST_ADGUARD_PASSWORD=REPLACE                        # vault: adguard_admin_password
NEST_HA_TOKEN=REPLACE                                # vault: homeassistant_bearer_token
NEST_GRAFANA_PASSWORD=REPLACE                        # vault: grafana_admin_password
NEST_SONARR_KEY=REPLACE                              # vault: sonarr_api_key
NEST_RADARR_KEY=REPLACE                              # vault: radarr_api_key
NEST_LIDARR_KEY=REPLACE                              # vault: lidarr_api_key
NEST_PROWLARR_KEY=REPLACE                            # vault: prowlarr_api_key
NEST_JELLYSEERR_KEY=REPLACE                          # vault: jellyseerr_api_key
NEST_JELLYFIN_KEY=REPLACE                            # vault: jellyfin_api_key
