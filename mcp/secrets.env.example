# nest-mcp credentials
# Copy to ~/.config/nest-mcp/secrets.env and fill in values.
# chmod 600 ~/.config/nest-mcp/secrets.env

# Proxmox — token from: terraform output -raw nest_mcp_token (after terraform apply)
NEST_PROXMOX_TOKEN=nest-mcp@pve!nest-mcp=REPLACE

# UniFi — local admin account on UDM Pro
NEST_UNIFI_USERNAME=REPLACE
NEST_UNIFI_PASSWORD=REPLACE

# AdGuard Home — from vault: adguard_admin_password
NEST_ADGUARD_PASSWORD=REPLACE

# Home Assistant — long-lived token from HA profile page
NEST_HA_TOKEN=REPLACE

# Grafana — from vault: grafana_admin_password
NEST_GRAFANA_PASSWORD=REPLACE

# *arr API keys — from vault: sonarr_api_key / radarr_api_key / etc.
NEST_SONARR_KEY=REPLACE
NEST_RADARR_KEY=REPLACE
NEST_LIDARR_KEY=REPLACE
NEST_PROWLARR_KEY=REPLACE

# Jellyfin — from Jellyfin dashboard > Administration > API Keys
NEST_JELLYFIN_KEY=REPLACE

# Jellyseerr — from vault: jellyseerr_api_key
NEST_JELLYSEERR_KEY=REPLACE
