# Audit output
audit.txt
playbooks/audit-output/

# Retry files
*.retry

# Terraform
terraform/.terraform/
# .terraform.lock.hcl is intentionally committed — pins provider versions
terraform/*.tfstate
terraform/*.tfstate.*
terraform/secrets.tfvars
terraform/.terraform.tfstate.lock.info

# MCP server config (contains credentials)
.mcp.json

# FoundryVTT zip (proprietary, downloaded from license page)
playbooks/provision/files/foundry/*.zip

# Talos cluster secrets (generated by bootstrap-talos.sh — keep offline)
# talosconfig and controlplane.yaml contain cluster CA keys
talos/clusterconfig/
__pycache__/
*.pyc

# Python test/coverage artifacts (mcp/)
.venv*/
mcp/.venv*/
mcp/coverage.xml
mcp/.coverage
.pytest_cache/
*.egg-info/
